{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Server (npx serve)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["server.py"],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    }
  ]
}
